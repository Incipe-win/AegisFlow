FROM golang:1.25-alpine AS builder

ARG GOPROXY
ARG GOSUMDB
ENV GOPROXY=${GOPROXY:-https://proxy.golang.org,direct}
ENV GOSUMDB=${GOSUMDB:-sum.golang.org}

WORKDIR /src
COPY apps/mcp/go.mod apps/mcp/go.sum ./
RUN go mod download
COPY apps/mcp/ ./
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /aegisflow-mcp .

FROM alpine:3.21
RUN apk add --no-cache ca-certificates tzdata
COPY --from=builder /aegisflow-mcp /aegisflow-mcp

EXPOSE 8090
ENTRYPOINT ["./aegisflow-mcp"]
